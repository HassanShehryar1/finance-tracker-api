{
  "info": {
    "name": "Finance Expense Tracker API",
    "_postman_id": "finance-tracker-sqe-2026",
    "description": "SQE Lab Project — Complete API testing for Finance Expense Tracker built with FastAPI. Covers GET, POST, PUT, PATCH, DELETE with 15+ test cases including validation and edge cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "expenseId", "value": "" }
  ],
  "item": [
    {
      "name": "Health & Setup",
      "item": [
        {
          "name": "TC01 - Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC01 - Status is 200', function() { pm.response.to.have.status(200); });",
              "pm.test('TC01 - Status field is healthy', function() { pm.expect(pm.response.json().status).to.eql('healthy'); });"
            ]}
          }]
        },
        {
          "name": "TC02 - Root Endpoint",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC02 - Status is 200', function() { pm.response.to.have.status(200); });",
              "pm.test('TC02 - API is running', function() { pm.expect(pm.response.json().status).to.eql('running'); });"
            ]}
          }]
        }
      ]
    },
    {
      "name": "GET Expenses",
      "item": [
        {
          "name": "TC03 - Get All Expenses (Empty)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/expenses", "host": ["{{baseUrl}}"], "path": ["expenses"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC03 - Status is 200', function() { pm.response.to.have.status(200); });",
              "pm.test('TC03 - Response is an array', function() { pm.expect(pm.response.json()).to.be.an('array'); });",
              "pm.test('TC03 - Response time under 500ms', function() { pm.expect(pm.response.responseTime).to.be.below(500); });"
            ]}
          }]
        }
      ]
    },
    {
      "name": "POST - Create Expenses",
      "item": [
        {
          "name": "TC04 - Create Expense (Food)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses", "host": ["{{baseUrl}}"], "path": ["expenses"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Weekly Groceries\", \"amount\": 45.50, \"category\": \"food\", \"description\": \"Superstore trip\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC04 - Status is 201 Created', function() { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.test('TC04 - ID is returned', function() { pm.expect(json.id).to.be.a('number'); });",
              "pm.test('TC04 - Title matches', function() { pm.expect(json.title).to.eql('Weekly Groceries'); });",
              "pm.test('TC04 - Amount matches', function() { pm.expect(json.amount).to.eql(45.5); });",
              "pm.test('TC04 - Category is food', function() { pm.expect(json.category).to.eql('food'); });",
              "pm.collectionVariables.set('expenseId', json.id);"
            ]}
          }]
        },
        {
          "name": "TC05 - Create Expense (Transport)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses", "host": ["{{baseUrl}}"], "path": ["expenses"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Uber Ride\", \"amount\": 12.00, \"category\": \"transport\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC05 - Status is 201 Created', function() { pm.response.to.have.status(201); });",
              "pm.test('TC05 - Category is transport', function() { pm.expect(pm.response.json().category).to.eql('transport'); });",
              "pm.test('TC05 - Description is null when not provided', function() { pm.expect(pm.response.json().description).to.be.null; });"
            ]}
          }]
        },
        {
          "name": "TC06 - Create Expense (Bills)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses", "host": ["{{baseUrl}}"], "path": ["expenses"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Electricity Bill\", \"amount\": 3200.00, \"category\": \"bills\", \"description\": \"Monthly LESCO bill\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC06 - Status is 201 Created', function() { pm.response.to.have.status(201); });",
              "pm.test('TC06 - Amount is correct', function() { pm.expect(pm.response.json().amount).to.eql(3200.0); });"
            ]}
          }]
        },
        {
          "name": "TC07 - Validation Error (Negative Amount)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses", "host": ["{{baseUrl}}"], "path": ["expenses"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Bad Expense\", \"amount\": -50, \"category\": \"food\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC07 - Status is 422 Unprocessable Entity', function() { pm.response.to.have.status(422); });",
              "pm.test('TC07 - Validation error returned', function() { pm.expect(pm.response.json()).to.have.property('detail'); });"
            ]}
          }]
        },
        {
          "name": "TC08 - Validation Error (Missing Required Fields)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses", "host": ["{{baseUrl}}"], "path": ["expenses"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Incomplete\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC08 - Status is 422 for missing fields', function() { pm.response.to.have.status(422); });"
            ]}
          }]
        },
        {
          "name": "TC09 - Validation Error (Invalid Category)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses", "host": ["{{baseUrl}}"], "path": ["expenses"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Test\", \"amount\": 10, \"category\": \"invalid_category\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC09 - Status is 422 for invalid category', function() { pm.response.to.have.status(422); });"
            ]}
          }]
        }
      ]
    },
    {
      "name": "GET Single Expense",
      "item": [
        {
          "name": "TC10 - Get Expense By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/expenses/{{expenseId}}", "host": ["{{baseUrl}}"], "path": ["expenses", "{{expenseId}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC10 - Status is 200', function() { pm.response.to.have.status(200); });",
              "pm.test('TC10 - ID matches requested ID', function() { pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('expenseId')); });",
              "pm.test('TC10 - Has all required fields', function() {",
              "  var json = pm.response.json();",
              "  pm.expect(json).to.have.all.keys('id','title','amount','category','description');",
              "});"
            ]}
          }]
        },
        {
          "name": "TC11 - Get Non-Existent Expense (404)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/expenses/9999", "host": ["{{baseUrl}}"], "path": ["expenses", "9999"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC11 - Status is 404 Not Found', function() { pm.response.to.have.status(404); });",
              "pm.test('TC11 - Error detail is returned', function() { pm.expect(pm.response.json()).to.have.property('detail'); });"
            ]}
          }]
        }
      ]
    },
    {
      "name": "PUT - Full Update",
      "item": [
        {
          "name": "TC12 - Full Update Expense (PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses/{{expenseId}}", "host": ["{{baseUrl}}"], "path": ["expenses", "{{expenseId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Updated Grocery Run\", \"amount\": 80.00, \"category\": \"shopping\", \"description\": \"Full replace via PUT\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC12 - Status is 200', function() { pm.response.to.have.status(200); });",
              "pm.test('TC12 - Title is updated', function() { pm.expect(pm.response.json().title).to.eql('Updated Grocery Run'); });",
              "pm.test('TC12 - Amount is updated', function() { pm.expect(pm.response.json().amount).to.eql(80.0); });",
              "pm.test('TC12 - Category changed to shopping', function() { pm.expect(pm.response.json().category).to.eql('shopping'); });"
            ]}
          }]
        },
        {
          "name": "TC13 - PUT Non-Existent Expense (404)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses/9999", "host": ["{{baseUrl}}"], "path": ["expenses", "9999"] },
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Ghost\", \"amount\": 10, \"category\": \"other\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC13 - Status is 404 for PUT on missing expense', function() { pm.response.to.have.status(404); });"
            ]}
          }]
        }
      ]
    },
    {
      "name": "PATCH - Partial Update",
      "item": [
        {
          "name": "TC14 - Partial Update Amount (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/expenses/{{expenseId}}", "host": ["{{baseUrl}}"], "path": ["expenses", "{{expenseId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 99.99}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC14 - Status is 200', function() { pm.response.to.have.status(200); });",
              "pm.test('TC14 - Amount is patched', function() { pm.expect(pm.response.json().amount).to.eql(99.99); });",
              "pm.test('TC14 - Title unchanged after PATCH', function() { pm.expect(pm.response.json().title).to.eql('Updated Grocery Run'); });"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Summary",
      "item": [
        {
          "name": "TC15 - Get Expense Summary",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/expenses/summary", "host": ["{{baseUrl}}"], "path": ["expenses", "summary"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('TC15 - Status is 200', function() { pm.response.to.have.status(200); });",
