              "pm.test('TC15 - Has total_expenses field', function() { pm.expect(json).to.have.property('total_expenses'); });",
              "pm.test('TC15 - Has total_amount field', function() { pm.expect(json).to.have.property('total_amount'); });",
              "pm.test('TC15 - Has by_category breakdown', function() { pm.expect(json).to.have.property('by_category'); });",
              "pm.test('TC15 - total_expenses is a number', function() { pm.expect(json.total_expenses).to.be.a('number'); });"
            ]}
          }]
        }
      ]
    },
